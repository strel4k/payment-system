{
  "uid": "ps-currency-rate-service",
  "title": "Payment System — Currency Rate Service",
  "tags": ["payment-system", "currency-rate-service"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Service UP",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"currency-rate-service\"}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Rate Updates Success Total",
      "gridPos": { "x": 4, "y": 0, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate_update_success_total{job=\"currency-rate-service\"}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Rate Updates Failures Total",
      "gridPos": { "x": 9, "y": 0, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate_update_failure_total{job=\"currency-rate-service\"}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Last Update Duration (s)",
      "gridPos": { "x": 14, "y": 0, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate_update_duration_seconds_sum{job=\"currency-rate-service\"} / rate_update_duration_seconds_count{job=\"currency-rate-service\"}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 30 }, { "color": "red", "value": 300 }] }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "JVM Heap Used (MB)",
      "gridPos": { "x": 19, "y": 0, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_memory_used_bytes{job=\"currency-rate-service\", area=\"heap\"} / 1024 / 1024",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "MB",
          "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 300 }, { "color": "red", "value": 450 }] }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"currency-rate-service\"}[1m])) by (uri)",
          "legendFormat": "{{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP Response Time P99 (ms)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"currency-rate-service\"}[1m])) by (le, uri)) * 1000",
          "legendFormat": "p99 {{uri}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"currency-rate-service\"}[1m])) by (le, uri)) * 1000",
          "legendFormat": "p95 {{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "HTTP Errors Rate (4xx / 5xx)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"currency-rate-service\", status=~\"4..\"}[1m]))",
          "legendFormat": "4xx"
        },
        {
          "refId": "B",
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"currency-rate-service\", status=~\"5..\"}[1m]))",
          "legendFormat": "5xx"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Rate Update Duration (s)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(rate_update_duration_seconds_sum{job=\"currency-rate-service\"}[5m]) / rate(rate_update_duration_seconds_count{job=\"currency-rate-service\"}[5m])",
          "legendFormat": "avg duration"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Rate Update Success vs Failure",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "increase(rate_update_success_total{job=\"currency-rate-service\"}[5m])",
          "legendFormat": "success"
        },
        {
          "refId": "B",
          "expr": "increase(rate_update_failure_total{job=\"currency-rate-service\"}[5m])",
          "legendFormat": "failure"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "success" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "failure" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "JVM Memory (Heap / Non-Heap)",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_memory_used_bytes{job=\"currency-rate-service\", area=\"heap\"} / 1024 / 1024",
          "legendFormat": "heap used (MB)"
        },
        {
          "refId": "B",
          "expr": "jvm_memory_used_bytes{job=\"currency-rate-service\", area=\"nonheap\"} / 1024 / 1024",
          "legendFormat": "non-heap used (MB)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "MB" },
        "overrides": []
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "DB Connection Pool (HikariCP)",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "hikaricp_connections_active{job=\"currency-rate-service\"}",
          "legendFormat": "active"
        },
        {
          "refId": "B",
          "expr": "hikaricp_connections_idle{job=\"currency-rate-service\"}",
          "legendFormat": "idle"
        },
        {
          "refId": "C",
          "expr": "hikaricp_connections_pending{job=\"currency-rate-service\"}",
          "legendFormat": "pending"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "CPU Usage",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "process_cpu_usage{job=\"currency-rate-service\"}",
          "legendFormat": "process CPU"
        },
        {
          "refId": "B",
          "expr": "system_cpu_usage{job=\"currency-rate-service\"}",
          "legendFormat": "system CPU"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      }
    },
    {
      "id": 14,
      "type": "logs",
      "title": "Currency Rate Service Logs (Loki)",
      "gridPos": { "x": 0, "y": 36, "w": 24, "h": 12 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"docker\", service=\"currency-rate-service\"}"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ],
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "query": "prometheus"
      },
      {
        "type": "datasource",
        "name": "DS_LOKI",
        "label": "Loki",
        "query": "loki"
      }
    ]
  }
}