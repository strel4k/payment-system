@startuml C4_Container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
LAYOUT_TOP_DOWN()
Person(user, "User", "Client of the payment system")
System_Boundary(ps, "Payment System") {
    Container(indApi, "Individuals API", "Spring Boot :8081", "Orchestrator: auth, wallets, transfers")
    Container(crs, "Currency Rate Service", "Spring Boot :8083", "Fetches, stores and serves exchange rates")
    Container(txSvc, "Transaction Service", "Spring Boot :8084", "Wallets and transactions (sharded)")
    Container(pSvc, "Person Service", "Spring Boot :8082", "User profile management")
    ContainerDb(crsDb, "currency-postgres", "PostgreSQL :5435", "currencies, conversion_rates, rate_providers, shedlock")
    ContainerDb(txDb, "transaction-postgres", "PostgreSQL :5432", "wallets, transactions")
    Container(keycloak, "Keycloak", ":8080", "Authentication & Authorization")
    Container(kafka, "Kafka", ":9092", "Event streaming")
    Container(ext, "exchangerate-api.com", "External HTTPS API", "Source of live exchange rates")
    Container(prometheus, "Prometheus", "Metrics", "Scrapes /actuator/prometheus")
    Container(loki, "Loki", "Logs", "Receives JSON log streams")
    Container(grafana, "Grafana", "Dashboards", "Metrics + Logs visualization")
}
Rel(user, indApi, "REST")
Rel(indApi, keycloak, "Token validation")
Rel(indApi, pSvc, "User CRUD", "WebClient")
Rel(indApi, crs, "GET /rates", "WebClient")
Rel(indApi, txSvc, "Init / Confirm transfer", "WebClient")
Rel(txSvc, kafka, "Transaction events")
Rel(txSvc, txDb, "JPA")
Rel(crs, ext, "GET /v6/{key}/latest/USD", "HTTPS")
Rel(crs, crsDb, "JPA / Flyway")
Rel(crs, prometheus, "metrics")
Rel(crs, loki, "JSON logs")
Rel(prometheus, grafana, "query")
Rel(loki, grafana, "query")
@enduml
